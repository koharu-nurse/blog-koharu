---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	relatedPosts?: CollectionEntry<'blog'>[];
};

const { title, description, pubDate, updatedDate, heroImage, category, relatedPosts = [] } = Astro.props;
const cat = CATEGORIES[category] ?? CATEGORIES.life;

// シェアボタン用の絶対URL（Astro.siteが未設定時はfallback）
const shareUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://koharu-nurse.com').href;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			schemaType="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
			category={category}
		/>
	</head>

	<body>
		<Header />
		<main>
			<article data-pagefind-body>
				<div class="hero-image">
					{heroImage ? (
						<Image width={1020} height={510} src={heroImage} alt="" />
					) : (
						<div class="hero-placeholder"><span>{cat.emoji}</span></div>
					)}
				</div>
				<div class="prose container">
					<!-- パンくず -->
					<nav class="crumbs" aria-label="パンくず">
						<a href="/">ホーム</a>
						<span>／</span>
						<a href="/blog/">記事一覧</a>
						<span>／</span>
						<a href={`/category/${category}/`}>{cat.label}</a>
					</nav>
					<div class="post-meta">
						<a href={`/category/${category}/`} class="post-category">{cat.label}</a>
						<span class="post-date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated">（更新：<FormattedDate date={updatedDate} />）</span>
							)}
						</span>
					</div>
					<h1 class="post-title">{title}</h1>
					<hr />
					<div class="post-body">
						<slot />
					</div>
				</div>
				<ShareButtons title={title} url={shareUrl} />
				{relatedPosts.length > 0 && (
					<aside class="related container" aria-label="関連記事">
						<h2 class="related-title">🌷 こちらも読まれています</h2>
						<div class="related-grid">
							{relatedPosts.map((rp) => {
								const rcat = CATEGORIES[rp.data.category] ?? CATEGORIES.life;
								return (
									<a href={`/blog/${rp.id}/`} class="related-card">
										<div class="related-thumb">
											<span class="related-emoji">{rcat.emoji}</span>
										</div>
										<div class="related-body">
											<span class="related-category">{rcat.label}</span>
											<h3 class="related-heading">{rp.data.title}</h3>
											<p class="related-date">
												<FormattedDate date={rp.data.pubDate} />
											</p>
										</div>
									</a>
								);
							})}
						</div>
					</aside>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: 0;
	}
	.hero-image {
		max-width: 1020px;
		margin: 30px auto 0;
		padding: 0 24px;
	}
	.hero-image :global(img) {
		display: block;
		margin: 0 auto;
		border-radius: 16px;
		box-shadow: var(--shadow);
		width: 100%;
		height: auto;
	}
	.hero-placeholder {
		aspect-ratio: 2 / 1;
		background: linear-gradient(135deg, #f3e5e1, #e8d3cd);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 120px;
		box-shadow: var(--shadow);
	}

	.prose {
		max-width: 760px;
		margin: 0 auto;
		padding: 40px 24px 60px;
		color: var(--text-main);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 16px;
		flex-wrap: wrap;
	}
	.crumbs {
		font-size: 12px;
		color: var(--text-sub);
		margin-bottom: 16px;
	}
	.crumbs a {
		color: var(--pink-deep);
	}
	.crumbs span {
		margin: 0 6px;
		color: var(--text-sub);
	}
	.post-category {
		display: inline-block;
		background: var(--bg-accent);
		color: var(--pink-deep);
		font-size: 12px;
		padding: 4px 12px;
		border-radius: 100px;
		font-weight: 700;
		transition: background 0.2s;
	}
	.post-category:hover {
		background: var(--pink-main);
		color: white;
	}
	.post-date {
		font-size: 13px;
		color: var(--text-sub);
	}
	.updated {
		margin-left: 8px;
	}
	.post-title {
		font-size: 28px;
		line-height: 1.5;
		margin-bottom: 24px;
	}
	hr {
		margin: 24px 0 32px;
	}
	.post-body :global(h2) {
		font-size: 22px;
		margin-top: 2.5em;
		margin-bottom: 0.8em;
		padding: 12px 16px;
		background: var(--bg-accent);
		border-left: 5px solid var(--pink-main);
		border-radius: 0 8px 8px 0;
	}
	.post-body :global(h3) {
		font-size: 18px;
		margin-top: 2em;
		margin-bottom: 0.6em;
		padding-bottom: 6px;
		border-bottom: 2px dashed var(--pink-main);
		color: var(--pink-deep);
	}
	.post-body :global(h4) {
		font-size: 16px;
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}
	.post-body :global(p) {
		margin-bottom: 1.4em;
		line-height: 1.9;
	}
	.post-body :global(ul),
	.post-body :global(ol) {
		margin: 0 0 1.4em 1.5em;
	}
	.post-body :global(li) {
		margin-bottom: 0.4em;
	}
	.post-body :global(img) {
		margin: 1.5em auto;
		border-radius: 12px;
		box-shadow: var(--shadow);
	}

	@media (max-width: 768px) {
		.post-title {
			font-size: 22px;
		}
		.post-body :global(h2) {
			font-size: 18px;
		}
		.post-body :global(h3) {
			font-size: 16px;
		}
	}

	/* 関連記事セクション */
	.related {
		max-width: 1020px;
		margin: 20px auto 60px;
		padding: 40px 24px 0;
		border-top: 1px solid var(--bg-accent);
	}
	.related-title {
		font-size: 22px;
		text-align: center;
		margin-bottom: 32px;
		color: var(--pink-deep);
	}
	.related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}
	.related-card {
		background: var(--bg-card);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: var(--shadow);
		transition: transform 0.3s, box-shadow 0.3s;
		display: block;
	}
	.related-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-hover);
	}
	.related-thumb {
		aspect-ratio: 16 / 10;
		background: linear-gradient(135deg, #f3e5e1, #e8d3cd);
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.related-emoji {
		font-size: 44px;
	}
	.related-body {
		padding: 16px;
	}
	.related-category {
		display: inline-block;
		background: var(--bg-accent);
		color: var(--pink-deep);
		font-size: 11px;
		padding: 3px 10px;
		border-radius: 100px;
		font-weight: 700;
		margin-bottom: 8px;
	}
	.related-heading {
		font-size: 15px;
		font-weight: 700;
		line-height: 1.5;
		margin-bottom: 8px;
	}
	.related-date {
		font-size: 12px;
		color: var(--text-sub);
		margin: 0;
	}

	@media (max-width: 1000px) {
		.related-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
