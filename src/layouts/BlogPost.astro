---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;
const cat = CATEGORIES[category] ?? CATEGORIES.life;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage ? (
						<Image width={1020} height={510} src={heroImage} alt="" />
					) : (
						<div class="hero-placeholder"><span>{cat.emoji}</span></div>
					)}
				</div>
				<div class="prose container">
					<div class="post-meta">
						<span class="post-category">{cat.label}</span>
						<span class="post-date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated">（更新：<FormattedDate date={updatedDate} />）</span>
							)}
						</span>
					</div>
					<h1 class="post-title">{title}</h1>
					<hr />
					<div class="post-body">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: 0;
	}
	.hero-image {
		max-width: 1020px;
		margin: 30px auto 0;
		padding: 0 24px;
	}
	.hero-image :global(img) {
		display: block;
		margin: 0 auto;
		border-radius: 16px;
		box-shadow: var(--shadow);
		width: 100%;
		height: auto;
	}
	.hero-placeholder {
		aspect-ratio: 2 / 1;
		background: linear-gradient(135deg, #f3e5e1, #e8d3cd);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 120px;
		box-shadow: var(--shadow);
	}

	.prose {
		max-width: 760px;
		margin: 0 auto;
		padding: 40px 24px 60px;
		color: var(--text-main);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 16px;
		flex-wrap: wrap;
	}
	.post-category {
		display: inline-block;
		background: var(--bg-accent);
		color: var(--pink-deep);
		font-size: 12px;
		padding: 4px 12px;
		border-radius: 100px;
		font-weight: 700;
	}
	.post-date {
		font-size: 13px;
		color: var(--text-sub);
	}
	.updated {
		margin-left: 8px;
	}
	.post-title {
		font-size: 28px;
		line-height: 1.5;
		margin-bottom: 24px;
	}
	hr {
		margin: 24px 0 32px;
	}
	.post-body :global(h2) {
		font-size: 22px;
		margin-top: 2.5em;
		margin-bottom: 0.8em;
		padding: 12px 16px;
		background: var(--bg-accent);
		border-left: 5px solid var(--pink-main);
		border-radius: 0 8px 8px 0;
	}
	.post-body :global(h3) {
		font-size: 18px;
		margin-top: 2em;
		margin-bottom: 0.6em;
		padding-bottom: 6px;
		border-bottom: 2px dashed var(--pink-main);
		color: var(--pink-deep);
	}
	.post-body :global(h4) {
		font-size: 16px;
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}
	.post-body :global(p) {
		margin-bottom: 1.4em;
		line-height: 1.9;
	}
	.post-body :global(ul),
	.post-body :global(ol) {
		margin: 0 0 1.4em 1.5em;
	}
	.post-body :global(li) {
		margin-bottom: 0.4em;
	}
	.post-body :global(img) {
		margin: 1.5em auto;
		border-radius: 12px;
		box-shadow: var(--shadow);
	}

	@media (max-width: 768px) {
		.post-title {
			font-size: 22px;
		}
		.post-body :global(h2) {
			font-size: 18px;
		}
		.post-body :global(h3) {
			font-size: 16px;
		}
	}
</style>
