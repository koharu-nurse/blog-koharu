---
// гғҲгғғгғ—гғҡгғјгӮёпјҡгғ’гғјгғӯгғјпјӢж–°зқҖиЁҳдәӢпјӢгғ—гғӯгғ•гӮЈгғјгғ«пјҲSTEENйўЁпјҡгӮўгӮӨгғңгғӘгғјГ—еўЁиүІГ—гғ–гғӯгғ–пјү
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, PROFILE, CATEGORIES, AVATAR_ILLUSTRATION } from '../consts';

// е…¬й–ӢиЁҳдәӢгӮ’ж–°гҒ—гҒ„й ҶгҒ«еҸ–еҫ—пјҲdraft=trueгҒҜйҷӨеӨ–пјү
const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = allPosts.slice(0, 6);

// гӮӨгғҒгӮӘгӮ·пјҲдё»еҠӣпјүиЁҳдәӢпјҡеҸҺзӣҠеҢ–гҒ®жҹұгҒЁгҒӘгӮӢ3иЁҳдәӢгҖӮIDгҒ§жҳҺзӨәзҡ„гҒ«жҢҮе®ҡ
const FEATURED_IDS = [
	'nurse-mama-20million-yen-journey',
	'nurse-mama-nisa-start-guide',
	'nurse-furusato-complete-guide',
];
const featuredPosts = FEATURED_IDS
	.map((id) => allPosts.find((p) => p.id === id))
	.filter((p): p is NonNullable<typeof p> => !!p);

const popularPosts = featuredPosts.length > 0 ? featuredPosts : allPosts.slice(0, 4);

// гӮ«гғҶгӮҙгғӘгҒ”гҒЁгҒ®иЁҳдәӢд»¶ж•°гӮ’йӣҶиЁҲпјҲгғҲгғғгғ—гҒ®гӮ«гғҶгӮҙгғӘгғҠгғ“иЎЁзӨәз”Ёпјү
const categoryStats = Object.entries(CATEGORIES).map(([slug, meta]) => ({
	slug,
	label: meta.label,
	emoji: meta.emoji,
	blobColor: meta.blobColor,
	en: meta.en,
	count: allPosts.filter((p) => p.data.category === slug).length,
}));
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- гғ’гғјгғӯгғјпјҡгӮўгӮҰгғҲгғ©гӮӨгғіиӢұеӯ—пјӢгғ–гғӯгғ–иЈ…йЈҫ -->
		<section class="hero">
			<div class="hero-content container">
				<div class="hero-text">
					<span class="hero-kicker">Koharu Nurse Blog</span>
					<h1 class="hero-title">
						<span class="hero-title-line">гӮҶгҒЈгҒҸгӮҠгҖҒгҒҳгҒ¶гӮ“гҒ®гғҡгғјгӮ№гҒ§</span>
						<span class="hero-title-line"><span class="hero-title-em">гҒҠйҮ‘гҒЁжҡ®гӮүгҒ—</span>гӮ’ж•ҙгҒҲгӮӢ</span>
					</h1>
					<p class="hero-lead">
						3е…җгҒ®гғһгғһгҒ§зҸҫеҪ№зңӢиӯ·её«гҒ®гҒ“гҒҜгӮӢгҒҢгҖҒ<br />
						иіҮз”Ј2000дёҮеҶҶгӮ’йҒ”жҲҗгҒҷгӮӢгҒҫгҒ§гҒ®е®¶иЁҲз®ЎзҗҶгғ»гҒӨгҒҝгҒҹгҒҰNISAгғ»еӣәе®ҡиІ»иҰӢзӣҙгҒ—гҒ®е®ҹдҪ“йЁ“гӮ’гҖҒгӮ„гҒ•гҒ—гҒ„иЁҖи‘үгҒ§гҒҠеұҠгҒ‘гҒ—гҒҫгҒҷгҖӮ
					</p>
					<a href="#featured" class="btn hero-btn">Read Articles</a>
				</div>
				<div class="hero-visual" aria-hidden="true">
					<div class="hero-blob hero-blob-1"></div>
					<div class="hero-blob hero-blob-2"></div>
					<div class="hero-blob hero-blob-3"></div>
					<span class="hero-outline">KOHARU</span>
				</div>
			</div>
		</section>

		<!-- гӮӨгғҒгӮӘгӮ·иЁҳдәӢпјҲдё»еҠӣ3жң¬пјү -->
		{featuredPosts.length > 0 && (
			<section class="featured container" id="featured">
				<div class="section-head">
					<span class="section-en outline-text">Featured</span>
					<h2 class="section-ja">гҒ“гҒҜгӮӢгҒ®гӮӨгғҒгӮӘгӮ·иЁҳдәӢ</h2>
					<p class="section-lead">гҒҫгҒҡгҒҜгҒ“гҒ“гҒӢгӮүиӘӯгӮ“гҒ§гҒ»гҒ—гҒ„гҖҒ3е…җгғһгғһзңӢиӯ·её«гҒ®е®ҹдҪ“йЁ“гҒҫгҒЁгӮҒ</p>
				</div>
				<div class="featured-grid">
					{featuredPosts.map((post, i) => {
						const cat = CATEGORIES[post.data.category] ?? CATEGORIES.life;
						return (
							<a href={`/blog/${post.id}/`} class="featured-card">
								<div class="featured-thumb">
									<div class="featured-blob blob-shape" style={`background: ${cat.blobColor};`}></div>
									{cat.illustration ? (
										<img class="featured-illust" src={cat.illustration} alt="" loading="lazy" />
									) : (
										<span class="featured-emoji">{cat.emoji}</span>
									)}
									<span class="featured-rank">No.{String(i + 1).padStart(2, '0')}</span>
								</div>
								<div class="featured-body">
									<span class="featured-category">{cat.en}</span>
									<h3 class="featured-title">{post.data.title}</h3>
								</div>
							</a>
						);
					})}
				</div>
			</section>
		)}

		<!-- гӮ«гғҶгӮҙгғӘгҒӢгӮүжҺўгҒҷпјҡгғ–гғӯгғ–7иүІ -->
		<section class="categories container">
			<div class="section-head">
				<span class="section-en outline-text">Category</span>
				<h2 class="section-ja">гӮ«гғҶгӮҙгғӘгҒӢгӮүжҺўгҒҷ</h2>
			</div>
			<div class="category-grid">
				{categoryStats.map((c, i) => {
					const cm = CATEGORIES[c.slug];
					return (
						<a href={`/category/${c.slug}/`} class="category-card">
							<div
								class={`category-blob blob-shape${(i % 4) + 1 === 1 ? '' : `-${(i % 4) + 1}`}`}
								style={`background: ${c.blobColor};`}
							>
								{cm?.illustration ? (
									<img class="category-illust" src={cm.illustration} alt="" loading="lazy" />
								) : (
									<span class="category-emoji">{c.emoji}</span>
								)}
							</div>
							<span class="category-label">{c.label}</span>
							<span class="category-en">{c.en}</span>
							<span class="category-count">{c.count} posts</span>
						</a>
					);
				})}
			</div>
		</section>

		<!-- гғЎгӮӨгғі2гӮ«гғ©гғ  -->
		<div class="layout container">
			<main>
				<div class="section-head">
					<span class="section-en outline-text">New Post</span>
					<h2 class="section-ja">ж–°зқҖиЁҳдәӢ</h2>
				</div>
				{latestPosts.length === 0 ? (
					<p class="empty">гҒҫгҒ иЁҳдәӢгҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ</p>
				) : (
					<div class="articles-grid">
						{latestPosts.map((post) => {
							const cat = CATEGORIES[post.data.category] ?? CATEGORIES.life;
							return (
								<a href={`/blog/${post.id}/`} class="article-card">
									<div class="article-thumb">
										{post.data.heroImage ? (
											<Image src={post.data.heroImage} alt="" width={400} height={250} />
										) : (
											<>
												<div class="article-blob blob-shape-2" style={`background: ${cat.blobColor};`}></div>
												{cat.illustration ? (
													<img class="article-illust" src={cat.illustration} alt="" loading="lazy" />
												) : (
													<span class="article-thumb-emoji">{cat.emoji}</span>
												)}
											</>
										)}
									</div>
									<div class="article-body">
										<span class="article-category">{cat.en}</span>
										<h3 class="article-title">{post.data.title}</h3>
										<p class="article-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</a>
							);
						})}
					</div>
				)}
			</main>

			<aside class="sidebar">
				<!-- гғ—гғӯгғ•гӮЈгғјгғ« -->
				<div class="profile-card">
					<div class="profile-avatar-wrap">
						<div class="profile-blob blob-shape"></div>
						<img class="profile-avatar-img" src={AVATAR_ILLUSTRATION} alt="гҒ“гҒҜгӮӢгҒ®гӮўгғҗгӮҝгғј" loading="lazy" />
					</div>
					<h3 class="profile-name">{PROFILE.name}</h3>
					<p class="profile-role">{PROFILE.role}</p>
					<p class="profile-bio">{PROFILE.bio}</p>
					<div class="profile-stats">
						{PROFILE.stats.map((stat) => (
							<div class="stat-item">
								<div class="stat-value">{stat.value}</div>
								<div class="stat-label">{stat.label}</div>
							</div>
						))}
					</div>
					<a href="/about/" class="profile-btn">View Profile</a>
				</div>

				<!-- з·ЁйӣҶйғЁгҒҠгҒҷгҒҷгӮҒиЁҳдәӢпјҲгӮӨгғҒгӮӘгӮ·3жң¬гҒЁйҖЈеӢ•пјү -->
				{popularPosts.length > 0 && (
					<div class="side-section">
						<h3 class="side-title">
							<span class="side-title-en">Pick up</span>
							гҒҫгҒҡгҒҜгҒ“гҒ®иЁҳдәӢгҒӢгӮү
						</h3>
						<ul class="popular-list">
							{popularPosts.map((post, i) => (
								<li>
									<span class="popular-rank">{String(i + 1).padStart(2, '0')}</span>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</li>
							))}
						</ul>
					</div>
				)}

				<!-- гӮ«гғҶгӮҙгғӘгӮҜгӮӨгғғгӮҜгғӘгғігӮҜ -->
				<div class="side-section">
					<h3 class="side-title">
						<span class="side-title-en">Category</span>
						гӮ«гғҶгӮҙгғӘгҒӢгӮүжҺўгҒҷ
					</h3>
					<ul class="side-category-list">
						{categoryStats.filter((c) => c.count > 0).map((c) => (
							<li>
								<a href={`/category/${c.slug}/`}>
									<span class="side-cat-emoji">{c.emoji}</span>
									<span>{c.label}</span>
									<span class="side-cat-count">{c.count}</span>
								</a>
							</li>
						))}
					</ul>
				</div>
			</aside>
		</div>

		<Footer />
	</body>
</html>

<style>
	/* ============================
	   гғ’гғјгғӯгғјгӮ»гӮҜгӮ·гғ§гғі
	   ============================ */
	.hero {
		background: var(--bg-main);
		padding: 80px 0 100px;
		position: relative;
		overflow: hidden;
	}
	.hero-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 50px;
		align-items: center;
	}
	.hero-kicker {
		display: inline-block;
		font-family: var(--font-display);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 22px;
	}
	.hero-title {
		font-size: 32px;
		font-weight: 500;
		color: var(--ink-main);
		line-height: 1.6;
		letter-spacing: 0.02em;
		margin-bottom: 24px;
		font-family: var(--font-heading);
	}
	/* 1иЎҢзӣ®гғ»2иЎҢзӣ®гӮ’еј·еҲ¶ж”№иЎҢгҖӮзӢӯгҒ„з”»йқўгҒ§гҒҜж–Үеӯ—гӮөгӮӨгӮәеҒҙгҒ§иӘҝж•ҙ */
	.hero-title-line {
		display: block;
	}
	.hero-title-em {
		position: relative;
		display: inline-block;
		font-weight: 700;
	}
	.hero-title-em::after {
		content: '';
		position: absolute;
		left: -4px;
		right: -4px;
		bottom: 4px;
		height: 10px;
		background: var(--blob-household);
		z-index: -1;
		opacity: 0.6;
	}
	.hero-lead {
		color: var(--ink-sub);
		font-size: 14px;
		line-height: 2;
		margin-bottom: 32px;
	}
	.hero-btn {
		font-size: 12px;
	}
	/* гғ’гғјгғӯгғјгғ“гӮёгғҘгӮўгғ«пјҡгғ–гғӯгғ–гҒЁеӨ§гҒҚгҒӘгӮўгӮҰгғҲгғ©гӮӨгғіиӢұеӯ— */
	.hero-visual {
		position: relative;
		height: 380px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.hero-blob {
		position: absolute;
		border-radius: 63% 37% 54% 46% / 55% 48% 52% 45%;
	}
	.hero-blob-1 {
		width: 260px;
		height: 260px;
		background: var(--blob-household);
		top: 20px;
		left: 40px;
		opacity: 0.85;
	}
	.hero-blob-2 {
		width: 180px;
		height: 180px;
		background: var(--blob-nisa);
		bottom: 30px;
		right: 30px;
		border-radius: 42% 58% 46% 54% / 60% 40% 60% 40%;
		opacity: 0.8;
	}
	.hero-blob-3 {
		width: 120px;
		height: 120px;
		background: var(--blob-nurse);
		top: 60px;
		right: 70px;
		border-radius: 56% 44% 70% 30% / 40% 60% 40% 60%;
		opacity: 0.7;
	}
	.hero-outline {
		position: relative;
		font-family: var(--font-display);
		font-size: 90px;
		font-weight: 500;
		letter-spacing: 0.1em;
		-webkit-text-stroke: 1.5px var(--ink-main);
		color: transparent;
		z-index: 2;
	}

	/* ============================
	   гӮ»гӮҜгӮ·гғ§гғіе…ұйҖҡгғҳгғғгғҖгғј
	   ============================ */
	.section-head {
		margin-bottom: 40px;
	}
	.section-en {
		display: block;
		font-size: 56px;
		font-weight: 500;
		margin-bottom: -18px;
		letter-spacing: 0.08em;
	}
	.section-ja {
		font-family: var(--font-heading);
		font-size: 22px;
		font-weight: 500;
		color: var(--ink-main);
		letter-spacing: 0.06em;
		margin-bottom: 8px;
	}
	.section-lead {
		color: var(--ink-sub);
		font-size: 13px;
		margin: 0;
	}

	/* ============================
	   гӮӨгғҒгӮӘгӮ·иЁҳдәӢ
	   ============================ */
	.featured {
		padding: 80px 24px 40px;
	}
	.featured-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px;
	}
	.featured-card {
		background: transparent;
		transition: transform 0.3s;
		display: block;
		color: inherit;
	}
	.featured-card:hover {
		transform: translateY(-6px);
	}
	.featured-thumb {
		aspect-ratio: 1 / 1;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 18px;
	}
	.featured-blob {
		position: absolute;
		inset: 8%;
		transition: transform 0.4s ease;
	}
	.featured-card:hover .featured-blob {
		transform: rotate(-4deg) scale(1.03);
	}
	.featured-emoji {
		font-size: 72px;
		position: relative;
		z-index: 1;
	}
	/* гӮӨгғҒгӮӘгӮ·иЁҳдәӢз”ЁгӮӨгғ©гӮ№гғҲпјҡгғ–гғӯгғ–гҒЁеҗҢгҒҳеҪўгҒ§йҮҚгҒӯгӮӢ */
	.featured-illust {
		position: absolute;
		inset: 8%;
		width: 84%;
		height: 84%;
		object-fit: cover;
		border-radius: 63% 37% 54% 46% / 55% 48% 52% 45%;
		z-index: 1;
	}
	.featured-rank {
		position: absolute;
		top: 0;
		right: 0;
		font-family: var(--font-display);
		font-size: 14px;
		font-weight: 700;
		color: var(--ink-main);
		letter-spacing: 0.08em;
		background: var(--bg-card);
		padding: 6px 12px;
		border-radius: 100px;
		z-index: 2;
	}
	.featured-body {
		padding: 0 4px;
	}
	.featured-category {
		display: inline-block;
		font-family: var(--font-display);
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.2em;
		color: var(--accent);
		margin-bottom: 10px;
	}
	.featured-title {
		font-family: var(--font-heading);
		font-size: 16px;
		font-weight: 500;
		color: var(--ink-main);
		line-height: 1.7;
		letter-spacing: 0.03em;
	}

	/* ============================
	   гӮ«гғҶгӮҙгғӘгҒӢгӮүжҺўгҒҷ
	   ============================ */
	.categories {
		padding: 80px 24px 40px;
	}
	.category-grid {
		display: grid;
		grid-template-columns: repeat(7, 1fr);
		gap: 18px;
	}
	.category-card {
		text-align: center;
		color: var(--ink-main);
		transition: transform 0.3s;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.category-card:hover {
		transform: translateY(-4px);
	}
	.category-card:hover .category-blob {
		transform: rotate(-6deg);
	}
	.category-blob {
		width: 100%;
		aspect-ratio: 1 / 1;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 12px;
		transition: transform 0.4s ease;
	}
	.category-emoji {
		font-size: 32px;
	}
	/* гӮ«гғҶгӮҙгғӘз”ЁгӮӨгғ©гӮ№гғҲпјҡиҰӘгғ–гғӯгғ–гҒЁеҗҢгҒҳеҪўгҒ§е…ЁйқўиҰҶгҒ„ */
	.category-illust {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: inherit;
	}
	.category-blob {
		position: relative;
		overflow: hidden;
	}
	.category-label {
		font-family: var(--font-heading);
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.05em;
		margin-bottom: 2px;
	}
	.category-en {
		font-family: var(--font-display);
		font-size: 9px;
		font-weight: 500;
		letter-spacing: 0.2em;
		color: var(--accent);
		margin-bottom: 2px;
	}
	.category-count {
		font-family: var(--font-display);
		font-size: 10px;
		color: var(--ink-light);
	}

	/* ============================
	   гғ¬гӮӨгӮўгӮҰгғҲпјҲж–°зқҖ + гӮөгӮӨгғүгғҗгғјпјү
	   ============================ */
	.layout {
		padding: 80px 24px;
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: 60px;
	}

	/* ============================
