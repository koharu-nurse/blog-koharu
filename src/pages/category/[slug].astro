---
// カテゴリ別記事一覧ページ（STEEN風）
// 例: /category/household/ → 家計管理カテゴリの記事のみ表示
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, CATEGORIES } from '../../consts';

// 静的パス生成：CATEGORIES に登録されている全カテゴリでページを作る
export async function getStaticPaths() {
	const allPosts = await getCollection('blog', ({ data }) => !data.draft);
	return Object.entries(CATEGORIES).map(([slug, meta]) => {
		const posts = allPosts
			.filter((p) => p.data.category === slug)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { slug },
			props: { slug, meta, posts },
		};
	});
}

const { slug, meta, posts } = Astro.props;
const pageTitle = `${meta.label}の記事一覧 | ${SITE_TITLE}`;
const pageDesc = `${meta.label}カテゴリの記事一覧です。看護師ママこはるが実体験から書いた${meta.label}に関するブログ記事を集めています。`;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={pageTitle} description={pageDesc} />
	</head>
	<body>
		<Header />
		<main class="container">
			<!-- カテゴリヘッダー：ブロブ背景付きエンブレム -->
			<div class="cat-header">
				<div class="cat-emblem">
					<div class="cat-blob" style={`background: ${meta.blobColor};`}></div>
					{meta.illustration ? (
						<img class="cat-illust" src={meta.illustration} alt="" />
					) : (
						<span class="cat-emoji">{meta.emoji}</span>
					)}
				</div>
				<span class="cat-en outline-text">{meta.en}</span>
				<h1 class="cat-title">{meta.label}</h1>
				<p class="cat-count">{posts.length} posts</p>
				<nav class="crumbs" aria-label="パンくず">
					<a href="/">Home</a> <span>/</span> <a href="/blog/">Articles</a> <span>/</span> <span aria-current="page">{meta.en}</span>
				</nav>
			</div>

			{posts.length === 0 ? (
				<div class="empty">
					<p>このカテゴリの記事はまだありません。</p>
					<a href="/blog/" class="back-link">Back to Articles</a>
				</div>
			) : (
				<div class="articles-grid">
					{posts.map((post) => {
						const cat = CATEGORIES[post.data.category] ?? CATEGORIES.life;
						return (
							<a href={`/blog/${post.id}/`} class="article-card">
								<div class="article-thumb">
									{post.data.heroImage ? (
										<Image src={post.data.heroImage} alt="" width={400} height={250} />
									) : (
										<>
											<div class="article-blob blob-shape-2" style={`background: ${cat.blobColor};`}></div>
											{cat.illustration ? (
												<img class="article-illust" src={cat.illustration} alt="" loading="lazy" />
											) : (
												<span class="article-thumb-emoji">{cat.emoji}</span>
											)}
										</>
									)}
								</div>
								<div class="article-body">
									<span class="article-category">{cat.en}</span>
									<h3 class="article-title">{post.data.title}</h3>
									<p class="article-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						);
					})}
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: 60px 24px 80px;
	}
	.cat-header {
		text-align: center;
		margin-bottom: 50px;
	}
	.cat-emblem {
		position: relative;
		width: 140px;
		height: 140px;
		margin: 0 auto 20px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.cat-blob {
		position: absolute;
		inset: 0;
		border-radius: 63% 37% 54% 46% / 55% 48% 52% 45%;
	}
	.cat-emoji {
		position: relative;
		z-index: 1;
		font-size: 56px;
	}
	.cat-illust {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 63% 37% 54% 46% / 55% 48% 52% 45%;
		z-index: 1;
	}
	.cat-en {
		display: block;
		font-size: 48px;
		margin-bottom: -14px;
	}
	.cat-title {
		font-family: var(--font-heading);
		font-size: 22px;
		font-weight: 500;
		color: var(--ink-main);
		letter-spacing: 0.06em;
		margin-bottom: 6px;
	}
	.cat-count {
		font-family: var(--font-display);
		font-size: 11px;
		letter-spacing: 0.2em;
		color: var(--accent);
		text-transform: uppercase;
		margin-bottom: 20px;
	}
	.crumbs {
		font-family: var(--font-display);
		font-size: 11px;
		letter-spacing: 0.15em;
		color: var(--ink-light);
		text-transform: uppercase;
	}
	.crumbs a {
		color: var(--ink-sub);
		transition: color 0.2s;
	}
	.crumbs a:hover {
		color: var(--ink-main);
	}
	.crumbs span {
		margin: 0 8px;
	}

	/* 記事カード：記事一覧ページと統一 */
	.articles-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px 28px;
	}
	.article-card {
		display: block;
		color: inherit;
		transition: transform 0.3s;
	}
	.article-card:hover {
		transform: translateY(-4px);
	}
	.article-card:hover .article-blob {
		transform: rotate(-3deg) scale(1.02);
	}
	.article-thumb {
		aspect-ratio: 1 / 1;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 16px;
		overflow: hidden;
	}
	.article-thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 20px;
	}
	.article-blob {
		position: absolute;
		inset: 8%;
		transition: transform 0.4s ease;
	}
	.article-thumb-emoji {
		font-size: 56px;
		position: relative;
		z-index: 1;
	}
	.article-illust {
		position: absolute;
		inset: 6%;
		width: 88%;
		height: 88%;
		object-fit: cover;
		border-radius: 42% 58% 46% 54% / 60% 40% 60% 40%;
		z-index: 1;
	}
	.article-body {
		padding: 0 4px;
	}
	.article-category {
		display: inline-block;
		font-family: var(--font-display);
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.2em;
		color: var(--accent);
		margin-bottom: 8px;
	}
	.article-title {
		font-family: var(--font-heading);
		font-size: 15px;
		font-weight: 500;
		line-height: 1.7;
		margin-bottom: 6px;
	}
	.article-date {
		font-family: var(--font-display);
		font-size: 11px;
		letter-spacing: 0.08em;
		color: var(--ink-light);
		margin: 0;
	}

	/* 記事0件のとき */
	.empty {
		text-align: center;
		padding: 60px 0;
	}
	.empty p {
		color: var(--ink-sub);
		margin-bottom: 24px;
	}
	.back-link {
		display: inline-block;
		background: var(--ink-main);
		color: var(--bg-main);
		padding: 14px 28px;
		font-family: var(--font-display);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		transition: background 0.2s;
	}
	.back-link:hover {
		background: var(--accent-deep);
	}

	@media (max-width: 1000px) {
		.articles-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.articles-grid {
			grid-template-columns: 1fr;
			gap: 36px;
		}
		.cat-title {
			font-size: 20px;
		}
		.cat-en {
			font-size: 36px;
		}
		.cat-emoji {
			font-size: 44px;
		}
	}
</style>
