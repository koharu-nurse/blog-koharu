---
// カテゴリ別記事一覧ページ（動的ルーティング）
// 例: /category/household/ → 家計管理カテゴリの記事のみ表示
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, CATEGORIES } from '../../consts';

// 静的パス生成：CATEGORIES に登録されている全カテゴリでページを作る
export async function getStaticPaths() {
	const allPosts = await getCollection('blog', ({ data }) => !data.draft);
	return Object.entries(CATEGORIES).map(([slug, meta]) => {
		const posts = allPosts
			.filter((p) => p.data.category === slug)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { slug },
			props: { slug, meta, posts },
		};
	});
}

const { slug, meta, posts } = Astro.props;
const pageTitle = `${meta.label}の記事一覧 | ${SITE_TITLE}`;
const pageDesc = `${meta.label}カテゴリの記事一覧です。看護師ママこはるが実体験から書いた${meta.label}に関するブログ記事を集めています。`;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={pageTitle} description={pageDesc} />
	</head>
	<body>
		<Header />
		<main class="container">
			<!-- カテゴリヘッダー -->
			<div class="cat-header">
				<div class="cat-emoji">{meta.emoji}</div>
				<h1 class="cat-title">{meta.label}</h1>
				<p class="cat-count">{posts.length}件の記事</p>
				<nav class="crumbs" aria-label="パンくず">
					<a href="/">ホーム</a> <span>／</span> <a href="/blog/">記事一覧</a> <span>／</span> <span aria-current="page">{meta.label}</span>
				</nav>
			</div>

			{posts.length === 0 ? (
				<div class="empty">
					<p>このカテゴリの記事はまだありません。</p>
					<a href="/blog/" class="back-link">← 記事一覧に戻る</a>
				</div>
			) : (
				<div class="articles-grid">
					{posts.map((post) => {
						const cat = CATEGORIES[post.data.category] ?? CATEGORIES.life;
						return (
							<a href={`/blog/${post.id}/`} class="article-card">
								<div class="article-thumb">
									{post.data.heroImage ? (
										<Image src={post.data.heroImage} alt="" width={400} height={250} />
									) : (
										<span class="article-thumb-emoji">{cat.emoji}</span>
									)}
								</div>
								<div class="article-body">
									<span class="article-category">{cat.label}</span>
									<h3 class="article-title">{post.data.title}</h3>
									<p class="article-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						);
					})}
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: 50px 24px 60px;
	}
	.cat-header {
		text-align: center;
		margin-bottom: 40px;
	}
	.cat-emoji {
		font-size: 64px;
		margin-bottom: 12px;
	}
	.cat-title {
		font-size: 28px;
		margin-bottom: 8px;
		color: var(--text-main);
	}
	.cat-count {
		font-size: 13px;
		color: var(--text-sub);
		margin-bottom: 20px;
	}
	.crumbs {
		font-size: 12px;
		color: var(--text-sub);
	}
	.crumbs a {
		color: var(--pink-deep);
	}
	.crumbs span {
		margin: 0 6px;
	}

	/* 記事カード（記事一覧ページと同じデザイン） */
	.articles-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}
	.article-card {
		background: var(--bg-card);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: var(--shadow);
		transition: transform 0.3s, box-shadow 0.3s;
		display: block;
	}
	.article-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-hover);
	}
	.article-thumb {
		aspect-ratio: 16 / 10;
		background: linear-gradient(135deg, #eaf0dc, #f7e7ce);
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}
	.article-thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.article-thumb-emoji {
		font-size: 48px;
		color: var(--pink-main);
	}
	.article-body {
		padding: 20px;
	}
	.article-category {
		display: inline-block;
		background: var(--bg-accent);
		color: var(--pink-deep);
		font-size: 11px;
		padding: 4px 10px;
		border-radius: 100px;
		font-weight: 700;
		margin-bottom: 10px;
	}
	.article-title {
		font-size: 16px;
		font-weight: 700;
		line-height: 1.5;
		margin-bottom: 10px;
	}
	.article-date {
		font-size: 12px;
		color: var(--text-sub);
		margin: 0;
	}

	/* 記事0件のとき */
	.empty {
		text-align: center;
		padding: 60px 0;
	}
	.empty p {
		color: var(--text-sub);
		margin-bottom: 20px;
	}
	.back-link {
		display: inline-block;
		background: var(--pink-main);
		color: white;
		padding: 10px 24px;
		border-radius: 100px;
		font-size: 13px;
		font-weight: 700;
	}
	.back-link:hover {
		background: var(--pink-deep);
	}

	@media (max-width: 1000px) {
		.articles-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.articles-grid {
			grid-template-columns: 1fr;
		}
		.cat-title {
			font-size: 22px;
		}
		.cat-emoji {
			font-size: 48px;
		}
	}
</style>
