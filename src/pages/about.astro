---
// プロフィールページ（STEEN風：ブロブ背景アバター＋墨色）
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, PROFILE, AVATAR_ILLUSTRATION } from '../consts';

const pageTitle = `プロフィール | ${SITE_TITLE}`;
const pageDesc = '看護師ママこはるのプロフィール。3児の母・現役看護師として家計管理ブログを運営しています。';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={pageTitle} description={pageDesc} />
	</head>
	<body>
		<Header />
		<main class="container prose">
			<div class="hero-card">
				<div class="avatar-wrap">
					<div class="avatar-blob"></div>
					<img class="avatar-img" src={AVATAR_ILLUSTRATION} alt="こはるのアバター" />
				</div>
				<span class="hero-en outline-text">About me</span>
				<h1>{PROFILE.name}</h1>
				<p class="role">{PROFILE.role}</p>
			</div>

			<h2>はじめまして、こはるです</h2>
			<p>
				このブログを開いてくださって、ありがとうございます。<br />
				現役の看護師として働きながら、3人の子どもを育てる毎日です。
			</p>

			<h2>家計を見直したきっかけ</h2>
			<p>
				夫がブラック企業で心身を消耗してしまい、転職を機に年収が大きく下がりました。<br />
				「このままじゃ家計がもたない」とゼロから家計を見直し、固定費削減・つみたてNISA・袋分け貯金を地道に続けて、資産2000万円に届きました。
			</p>

			<h2>このブログで発信していること</h2>
			<ul>
				<li>看護師ママでもムリなく続く家計管理</li>
				<li>つみたてNISA・新NISAの始め方と続け方</li>
				<li>固定費見直し（通信費・保険など）の実体験</li>
				<li>3児育児と仕事の両立で気づいたこと</li>
			</ul>

			<h2>大切にしていること</h2>
			<blockquote>
				<p><strong>「がんばりすぎない家計管理」</strong></p>
				<p>節約や投資は、続かないと意味がない。私自身、めんどくさがりで完璧主義じゃないからこそ、続けられるラインを大切にしています。</p>
			</blockquote>

			<h2>運営者情報</h2>
			<ul>
				<li>名前：{PROFILE.name}</li>
				<li>職業：現役看護師（3児の母）</li>
				<li>連絡先：<a href="/contact/">お問い合わせフォーム</a></li>
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 760px;
		padding: 60px 24px 80px;
	}
	.hero-card {
		text-align: center;
		margin-bottom: 50px;
	}
	.avatar-wrap {
		position: relative;
		width: 160px;
		height: 160px;
		margin: 0 auto 24px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.avatar-blob {
		position: absolute;
		inset: 0;
		border-radius: 63% 37% 54% 46% / 55% 48% 52% 45%;
		background: var(--blob-nurse);
	}
	.avatar-emoji {
		position: relative;
		z-index: 1;
		font-size: 64px;
	}
	.avatar-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 63% 37% 54% 46% / 55% 48% 52% 45%;
		z-index: 1;
	}
	.hero-en {
		display: block;
		font-size: 46px;
		margin-bottom: -14px;
	}
	.hero-card h1 {
		font-family: var(--font-heading);
		font-size: 24px;
		font-weight: 500;
		letter-spacing: 0.06em;
		margin-bottom: 6px;
	}
	.role {
		font-family: var(--font-display);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.3em;
		color: var(--accent);
		text-transform: uppercase;
		margin-bottom: 0;
	}

	/* 本文見出し：墨色シンプル系（BlogPostと統一） */
	.prose :global(h2) {
		font-family: var(--font-heading);
		font-size: 22px;
		font-weight: 700;
		margin-top: 2.5em;
		margin-bottom: 0.8em;
		padding-bottom: 12px;
		border-bottom: 2px solid var(--ink-main);
		color: var(--ink-main);
		letter-spacing: 0.04em;
	}
	.prose :global(p) {
		margin-bottom: 1.4em;
		line-height: 2;
	}
	.prose :global(ul) {
		margin: 0 0 1.4em 1.5em;
	}
	.prose :global(li) {
		margin-bottom: 0.4em;
	}
</style>
