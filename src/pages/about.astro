---
// プロフィールページ
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, PROFILE } from '../consts';

const pageTitle = `プロフィール | ${SITE_TITLE}`;
const pageDesc = '看護師ママこはるのプロフィール。3児の母・現役看護師として家計管理ブログを運営しています。';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={pageTitle} description={pageDesc} />
	</head>
	<body>
		<Header />
		<main class="container prose">
			<div class="hero-card">
				<div class="avatar">👩‍⚕️</div>
				<h1>{PROFILE.name}</h1>
				<p class="role">{PROFILE.role}</p>
			</div>

			<h2>はじめまして、こはるです🌷</h2>
			<p>
				このブログを開いてくださって、ありがとうございます。<br />
				現役の看護師として働きながら、3人の子どもを育てる毎日です。
			</p>

			<h2>家計を見直したきっかけ</h2>
			<p>
				夫がブラック企業で心身を消耗してしまい、転職を機に年収が大きく下がりました。<br />
				「このままじゃ家計がもたない」とゼロから家計を見直し、固定費削減・つみたてNISA・袋分け貯金を地道に続けて、資産2000万円に届きました。
			</p>

			<h2>このブログで発信していること</h2>
			<ul>
				<li>看護師ママでもムリなく続く家計管理</li>
				<li>つみたてNISA・新NISAの始め方と続け方</li>
				<li>固定費見直し（通信費・保険など）の実体験</li>
				<li>3児育児と仕事の両立で気づいたこと</li>
			</ul>

			<h2>大切にしていること</h2>
			<blockquote>
				<p><strong>「がんばりすぎない家計管理」</strong></p>
				<p>節約や投資は、続かないと意味がない。私自身、めんどくさがりで完璧主義じゃないからこそ、続けられるラインを大切にしています。</p>
			</blockquote>

			<h2>運営者情報</h2>
			<ul>
				<li>名前：{PROFILE.name}</li>
				<li>職業：現役看護師（3児の母）</li>
				<li>連絡先：<a href="/contact/">お問い合わせフォーム</a></li>
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 760px;
		padding: 50px 24px 60px;
	}
	.hero-card {
		background: linear-gradient(135deg, #faf0ec 0%, #f3e5e1 100%);
		border-radius: 20px;
		padding: 40px 24px;
		text-align: center;
		margin-bottom: 40px;
		box-shadow: var(--shadow);
	}
	.avatar {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		background: linear-gradient(135deg, #f3e5e1, #d4a5a5);
		margin: 0 auto 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 56px;
		border: 4px solid white;
		box-shadow: var(--shadow);
	}
	.hero-card h1 {
		font-size: 24px;
		margin-bottom: 4px;
	}
	.role {
		font-size: 13px;
		color: var(--pink-deep);
		font-weight: 700;
		letter-spacing: 0.05em;
		margin-bottom: 0;
	}
</style>
