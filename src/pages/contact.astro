---
// お問い合わせページ（STEEN風）
// Cloudflare PagesはPHPが動かないため、Formspree（無料サービス）を想定
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

// Formspreeのフォームエンドポイント（要差し替え）
// 1. https://formspree.io/ で無料アカウント作成
// 2. New Form → Email先を koharu.nurse.info@gmail.com に
// 3. 発行された https://formspree.io/f/xxxxxxxx を下に貼る
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/REPLACE_WITH_YOUR_FORM_ID';
const CONTACT_EMAIL = 'koharu.nurse.info@gmail.com';
const isFormspreeConfigured = !FORMSPREE_ENDPOINT.includes('REPLACE_WITH_YOUR_FORM_ID');

const pageTitle = `お問い合わせ | ${SITE_TITLE}`;
const pageDesc = 'こはるへのお問い合わせはこちらのフォームまたはメールでお願いします。';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={pageTitle} description={pageDesc} />
	</head>
	<body>
		<Header />
		<main class="container">
			<div class="page-head">
				<span class="page-en outline-text">Contact</span>
				<h1 class="page-title">お問い合わせ</h1>
				<p class="lead">
					ブログを読んでくださってありがとうございます。<br />
					ご質問・ご感想・お仕事のご依頼など、お気軽にどうぞ。
				</p>
			</div>

			{isFormspreeConfigured ? (
				<form class="contact-form" action={FORMSPREE_ENDPOINT} method="POST">
					<label>
						お名前 <span class="req">必須</span>
						<input type="text" name="name" required />
					</label>
					<label>
						メールアドレス <span class="req">必須</span>
						<input type="email" name="email" required />
					</label>
					<label>
						件名
						<input type="text" name="subject" />
					</label>
					<label>
						メッセージ <span class="req">必須</span>
						<textarea name="message" rows="8" required></textarea>
					</label>
					<button type="submit" class="submit-btn">Send Message</button>
				</form>
			) : (
				<div class="setup-notice">
					<p class="notice-label">Mail</p>
					<p>
						下記アドレスまでメールをお送りください：<br />
						<a href={`mailto:${CONTACT_EMAIL}`} class="email-link">{CONTACT_EMAIL}</a>
					</p>
					<p class="note">※ お問い合わせフォームは現在準備中です。</p>
				</div>
			)}

			<section class="info">
				<h2>返信について</h2>
				<p>
					3児ママで看護師として働いているため、お返事まで2〜3日いただくことがあります。<br />
					ご了承くださいませ。
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 700px;
		padding: 60px 24px 80px;
	}
	.page-head {
		text-align: center;
		margin-bottom: 48px;
	}
	.page-en {
		display: block;
		font-size: 56px;
		margin-bottom: -16px;
	}
	.page-title {
		font-family: var(--font-heading);
		font-size: 22px;
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--ink-main);
		margin-bottom: 16px;
	}
	.lead {
		color: var(--ink-sub);
		font-size: 14px;
		line-height: 2;
	}

	/* フォーム：白背景のシンプルなカード（ブロブではなく墨色区切りで統一感） */
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 22px;
		background: var(--bg-card);
		padding: 36px 32px;
		border: 1px solid var(--border);
	}
	.contact-form label {
		display: flex;
		flex-direction: column;
		gap: 8px;
		font-family: var(--font-heading);
		font-weight: 500;
		font-size: 13px;
		color: var(--ink-main);
		letter-spacing: 0.04em;
	}
	.req {
		display: inline-block;
		background: var(--ink-main);
		color: var(--bg-main);
		font-family: var(--font-display);
		font-size: 9px;
		padding: 2px 8px;
		margin-left: 6px;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}
	.contact-form input,
	.contact-form textarea {
		width: 100%;
		padding: 12px 14px;
		border: 1px solid var(--border);
		border-radius: 0;
		font-size: 14px;
		font-family: var(--font-body);
		background: #fff;
		color: var(--ink-main);
		font-weight: 400;
	}
	.contact-form input:focus,
	.contact-form textarea:focus {
		outline: 2px solid var(--ink-main);
		outline-offset: -1px;
	}
	.submit-btn {
		background: var(--ink-main);
		color: var(--bg-main);
		border: none;
		padding: 16px;
		font-family: var(--font-display);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 0.2s;
		margin-top: 12px;
	}
	.submit-btn:hover {
		background: var(--accent-deep);
	}

	.setup-notice {
		background: var(--bg-card);
		padding: 36px 32px;
		border: 1px solid var(--border);
		text-align: center;
	}
	.notice-label {
		font-family: var(--font-display);
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.3em;
		color: var(--accent);
		text-transform: uppercase;
		margin-bottom: 12px;
	}
	.email-link {
		font-family: var(--font-heading);
		font-size: 18px;
		color: var(--ink-main);
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-underline-offset: 4px;
		font-weight: 500;
		display: inline-block;
		padding: 8px 0;
	}
	.note {
		font-size: 12px;
		color: var(--ink-light);
		margin-top: 16px;
	}

	.info {
		margin-top: 48px;
		padding-top: 32px;
		border-top: 1px solid var(--border);
	}
	.info h2 {
		font-family: var(--font-heading);
		font-size: 16px;
		font-weight: 700;
		margin-bottom: 12px;
		color: var(--ink-main);
		letter-spacing: 0.04em;
	}
	.info p {
		font-size: 13px;
		margin: 0;
		color: var(--ink-sub);
		line-height: 2;
	}
</style>
