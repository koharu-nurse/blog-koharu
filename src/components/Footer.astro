---
import { SITE_TITLE, SITE_TAGLINE, CATEGORIES } from '../consts';
const today = new Date();

// カテゴリ一覧はCATEGORIES定数から動的に取得（追加時も自動反映）
const categoryLinks = Object.entries(CATEGORIES).map(([slug, meta]) => ({
	slug,
	label: meta.label,
	emoji: meta.emoji,
	en: meta.en,
}));
---

<footer class="footer">
	<div class="footer-container">
		<div class="footer-grid">
			<!-- サイト情報 -->
			<div class="footer-col">
				<span class="footer-brand-en">Koharu Nurse Blog</span>
				<h3 class="footer-heading">{SITE_TITLE}</h3>
				<p class="footer-desc">{SITE_TAGLINE}</p>
				<p class="footer-desc-small">
					3児のママで現役看護師のこはるが、<br />
					がんばりすぎない家計管理を発信中。
				</p>
			</div>

			<!-- カテゴリ -->
			<div class="footer-col">
				<h3 class="footer-heading"><span class="footer-en">Category</span>カテゴリ</h3>
				<ul class="footer-list">
					{categoryLinks.map((c) => (
						<li>
							<a href={`/category/${c.slug}/`}>
								<span class="footer-cat-emoji">{c.emoji}</span>
								{c.label}
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- 情報 -->
			<div class="footer-col">
				<h3 class="footer-heading"><span class="footer-en">Information</span>このサイトについて</h3>
				<ul class="footer-list">
					<li><a href="/about/">プロフィール</a></li>
					<li><a href="/blog/">記事一覧</a></li>
					<li><a href="/search/">記事を検索</a></li>
					<li><a href="/contact/">お問い合わせ</a></li>
					<li><a href="/privacy/">プライバシーポリシー</a></li>
					<li><a href="/rss.xml">RSSフィード</a></li>
				</ul>
			</div>
		</div>

		<div class="footer-bottom">
			<p>© {today.getFullYear()} {SITE_TITLE}</p>
			<p class="footer-disclaimer">
				本サイトの情報は執筆時点のものです。投資・税務・保険の最終判断はご自身の責任で行ってください。
			</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: var(--bg-soft);
		margin-top: 80px;
		padding: 60px 24px 32px;
		color: var(--ink-sub);
		font-size: 13px;
	}
	.footer-container {
		max-width: 1020px;
		margin: 0 auto;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 1.6fr 1fr 1fr;
		gap: 40px;
		margin-bottom: 36px;
	}
	.footer-col {
		display: flex;
		flex-direction: column;
	}
	.footer-brand-en {
		font-family: var(--font-display);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.3em;
		color: var(--accent);
		text-transform: uppercase;
		margin-bottom: 8px;
	}
	.footer-heading {
		font-family: var(--font-heading);
		font-size: 16px;
		font-weight: 500;
		color: var(--ink-main);
		margin-bottom: 16px;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--ink-main);
		letter-spacing: 0.05em;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.footer-en {
		font-family: var(--font-display);
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 0.3em;
		color: var(--accent);
		text-transform: uppercase;
	}
	.footer-desc {
		font-family: var(--font-display);
		font-size: 10px;
		font-weight: 700;
		color: var(--accent);
		margin-bottom: 12px;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}
	.footer-desc-small {
		font-size: 12px;
		line-height: 1.9;
		color: var(--ink-sub);
	}
	.footer-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.footer-list a {
		font-size: 13px;
		color: var(--ink-sub);
		transition: color 0.2s;
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}
	.footer-list a:hover {
		color: var(--ink-main);
	}
	.footer-cat-emoji {
		font-size: 14px;
	}
	.footer-bottom {
		padding-top: 24px;
		border-top: 1px solid var(--border);
		text-align: center;
	}
	.footer-bottom p {
		margin: 0 0 6px;
		font-size: 12px;
	}
	.footer-disclaimer {
		font-size: 11px;
		color: var(--ink-light);
	}

	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 32px;
		}
		.footer {
			padding: 50px 20px 28px;
		}
	}
</style>
